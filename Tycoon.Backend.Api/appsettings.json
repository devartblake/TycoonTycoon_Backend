{
  "ConnectionStrings": {
    "db": "Host=localhost;Port=5432;Database=tycoon_db;Username=tycoon_user;Password=tycoon_password_123",
    "redis": "localhost:6379,password=tycoon_redis_password_123,defaultDatabase=0",
    "mongo": "mongodb://tycoon_admin:tycoon_mongo_password_123@localhost:27017/tycoon_db?authSource=admin",
    "elasticsearch": "http://elastic:tycoon_elastic_password_123@localhost:9200"
  },
  "Mongo": {
    "Database": "tycoon_analytics"
  },
  "Analytics": {
    "Enabled": true
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire",
    "WorkerCount": 10
  },
  //"Auth": {
  //  "JwtKey": "your-super-secret-jwt-key-change-me-in-production-minimum-32-characters-long",
  //  "JwtIssuer": "TycoonBackend",
  //  "JwtAudience": "TycoonClient",
  //  "AccessTokenExpirationMinutes": 60,
  //  "RefreshTokenExpirationDays": 30
  //},
  "JwtSettings": {
    "SecretKey": "YOUR-SUPER-SECRET-KEY-MINIMUM-32-CHARACTERS-LONG-FOR-SECURITY",
    "Issuer": "TycoonBackendApi",
    "Audience": "TycoonFrontendApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Iap": {
    "EnableStrictValidation": false,
    "AppleSharedSecret": "__IAP_APPLE_SHARED_SECRET__",
    "GooglePackageName": "__IAP_GOOGLE_PACKAGE_NAME__",
    "GoogleServiceAccountJsonPath": "__IAP_GOOGLE_SERVICE_ACCOUNT_JSON_PATH__",
    "GoogleApiAccessToken": "__IAP_GOOGLE_API_ACCESS_TOKEN__"
  },
  "Stripe": {
    "Enabled": false,
    "SecretKey": "__STRIPE_SECRET_KEY__",
    "PublishableKey": "__STRIPE_PUBLISHABLE_KEY__",
    "WebhookSecret": "__STRIPE_WEBHOOK_SECRET__",
    "SuccessUrl": "https://localhost:3000/store/success?session_id={CHECKOUT_SESSION_ID}",
    "CancelUrl": "https://localhost:3000/store/cancel",
    "PortalReturnUrl": "https://localhost:3000/store/subscription",
    "AllowPromotionCodes": true,
    "AutomaticTax": false,
    "DefaultCurrency": "usd",
    "Catalog": [
      {
        "Sku": "powerup:skip",
        "UnitAmount": 299,
        "Currency": "usd",
        "ProductName": "Skip Powerup"
      }
    ],
    "SubscriptionPlans": [
      {
        "Tier": "premium",
        "BillingPeriod": "monthly",
        "PriceId": "__STRIPE_PRICE_PREMIUM_MONTHLY__",
        "ProductName": "Premium Monthly"
      },
      {
        "Tier": "elite",
        "BillingPeriod": "monthly",
        "PriceId": "__STRIPE_PRICE_ELITE_MONTHLY__",
        "ProductName": "Elite Monthly"
      },
      {
        "Tier": "premium",
        "BillingPeriod": "seasonal",
        "PriceId": "__STRIPE_PRICE_PREMIUM_SEASONAL__",
        "ProductName": "Premium Seasonal"
      },
      {
        "Tier": "elite",
        "BillingPeriod": "seasonal",
        "PriceId": "__STRIPE_PRICE_ELITE_SEASONAL__",
        "ProductName": "Elite Seasonal"
      }
    ]
  },
  "PayPal": {
    "Enabled": false,
    "ClientId": "__PAYPAL_CLIENT_ID__",
    "ClientSecret": "__PAYPAL_CLIENT_SECRET__",
    "BaseUrl": "https://api-m.sandbox.paypal.com",
    "ReturnUrl": "https://localhost:3000/store/paypal/return",
    "CancelUrl": "https://localhost:3000/store/paypal/cancel",
    "BrandName": "Tycoon",
    "WebhookId": "__PAYPAL_WEBHOOK_ID__",
    "Catalog": [
      {
        "Sku": "powerup:skip",
        "Currency": "USD",
        "UnitAmount": 2.99
      }
    ],
    "SubscriptionPlans": [
      {
        "Tier": "premium",
        "BillingPeriod": "monthly",
        "PlanId": "__PAYPAL_PLAN_PREMIUM_MONTHLY__",
        "DisplayName": "Premium Monthly"
      },
      {
        "Tier": "elite",
        "BillingPeriod": "monthly",
        "PlanId": "__PAYPAL_PLAN_ELITE_MONTHLY__",
        "DisplayName": "Elite Monthly"
      },
      {
        "Tier": "premium",
        "BillingPeriod": "seasonal",
        "PlanId": "__PAYPAL_PLAN_PREMIUM_SEASONAL__",
        "DisplayName": "Premium Seasonal"
      },
      {
        "Tier": "elite",
        "BillingPeriod": "seasonal",
        "PlanId": "__PAYPAL_PLAN_ELITE_SEASONAL__",
        "DisplayName": "Elite Seasonal"
      }
    ]
  },
  "Crypto": {
    "Enabled": true,
    "AllowedNetworks": [ "solana", "xrp", "shib", "snx" ],
    "MinWithdrawalUnits": 1,
    "HotWalletAddress": "__CRYPTO_HOT_WALLET_ADDRESS__"
  },
  "SidecarInference": {
    "EnableQuestionDifficultyEstimator": false,
    "QuestionDifficultyUrl": "http://localhost:8000/ml/question-difficulty"
  },
  "MlModels": {
    "QuestionDifficultyUrl": "__ML_QUESTION_DIFFICULTY_URL__",
    "ChurnRiskUrl": "__ML_CHURN_RISK_URL__",
    "MatchQualityUrl": "__ML_MATCH_QUALITY_URL__",
    "ApiKey": "__ML_MODELS_API_KEY__"
  },
  "Elastic": {
    "Url": "http://localhost:9200",
    "DailyWriteAlias": "tycoon-qa-daily-rollups",
    "PlayerDailyWriteAlias": "tycoon-qa-player-daily-rollups"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:8200",
      "https://localhost:8200",
      "http://localhost:63033",
      "https://localhost:63033"
    ]
  },
  "AdminOps": {
    "Enabled": true,
    "Header": "X-Admin-Ops-Key",
    "Key": "CHANGE_ME"
  },
  "Observability": {
    "ServiceName": "Tycoon.Backend.Api",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning",
      "Hangfire": "Information"
    }
  },
  "Parameters": {
    "admin": "admin",
    "postgres-admin": "postgres",
    "admin-password": "admin"
  }
}
