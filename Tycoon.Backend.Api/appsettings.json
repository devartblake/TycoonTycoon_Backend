{
  "ConnectionStrings": {
    "db": "Host=localhost;Port=5432;Database=tycoon_db;Username=tycoon_user;Password=tycoon_password_123",
    "redis": "localhost:6379,password=tycoon_redis_password_123,defaultDatabase=0",
    "mongo": "mongodb://tycoon_admin:tycoon_mongo_password_123@localhost:27017/tycoon_db?authSource=admin",
    "elasticsearch": "http://elastic:tycoon_elastic_password_123@localhost:9200"
  },
  "Mongo": {
    "Database": "tycoon_analytics"
  },
  "Analytics": {
    "Enabled": true
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire",
    "WorkerCount": 10
  },
  //"Auth": {
  //  "JwtKey": "your-super-secret-jwt-key-change-me-in-production-minimum-32-characters-long",
  //  "JwtIssuer": "TycoonBackend",
  //  "JwtAudience": "TycoonClient",
  //  "AccessTokenExpirationMinutes": 60,
  //  "RefreshTokenExpirationDays": 30
  //},
  "JwtSettings": {
    "SecretKey": "YOUR-SUPER-SECRET-KEY-MINIMUM-32-CHARACTERS-LONG-FOR-SECURITY",
    "Issuer": "TycoonBackendApi",
    "Audience": "TycoonFrontendApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Iap": {
    "EnableStrictValidation": false,
    "AppleSharedSecret": "__IAP_APPLE_SHARED_SECRET__",
    "GooglePackageName": "__IAP_GOOGLE_PACKAGE_NAME__",
    "GoogleServiceAccountJsonPath": "__IAP_GOOGLE_SERVICE_ACCOUNT_JSON_PATH__",
    "GoogleApiAccessToken": "__IAP_GOOGLE_API_ACCESS_TOKEN__"
  },
  "Crypto": {
    "Enabled": true,
    "AllowedNetworks": [ "solana", "ethereum" ],
    "MinWithdrawalUnits": 1,
    "HotWalletAddress": "__CRYPTO_HOT_WALLET_ADDRESS__"
  },
  "SidecarInference": {
    "EnableQuestionDifficultyEstimator": false,
    "QuestionDifficultyUrl": "http://localhost:8000/ml/question-difficulty"
  },
  "MlModels": {
    "QuestionDifficultyUrl": "__ML_QUESTION_DIFFICULTY_URL__",
    "ApiKey": "__ML_MODELS_API_KEY__"
  },
  "Elastic": {
    "Url": "http://localhost:9200",
    "DailyWriteAlias": "tycoon-qa-daily-rollups",
    "PlayerDailyWriteAlias": "tycoon-qa-player-daily-rollups"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:8200",
      "https://localhost:8200",
      "http://localhost:63033",
      "https://localhost:63033"
    ]
  },
  "AdminOps": {
    "Enabled": true,
    "Header": "X-Admin-Ops-Key",
    "Key": "CHANGE_ME"
  },
  "Observability": {
    "ServiceName": "Tycoon.Backend.Api",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning",
      "Hangfire": "Information"
    }
  },
  "Parameters": {
    "admin": "admin",
    "postgres-admin": "postgres",
    "admin-password": "admin"
  }
}
