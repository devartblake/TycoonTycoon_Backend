{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "db": "Host=localhost;Port=5432;Database=tycoon_db;Username=tycoon_user;Password=tycoon_password_123",
    "mongo": "mongodb://tycoon_admin:tycoon_mongo_password_123@localhost:27017/tycoon_db?authSource=admin",
    "elasticsearch": "http://localhost:9200",
    "PostgreSQL": "Host=localhost;Port=5432;Database=tycoon_db;Username=tycoon_user;Password=tycoon_password_123",
    "MongoDB": "mongodb://tycoon_admin:tycoon_mongo_password_123@localhost:27017/tycoon_db?authSource=admin",
    "Redis": "localhost:6379,password=tycoon_redis_password_123",
    "HangfireDB": "Host=localhost;Port=5432;Database=tycoon_db;Username=tycoon_user;Password=tycoon_password_123"
  },
  "ElasticSearch": {
    "Uri": "http://localhost:9200",
    "Username": "elastic",
    "Password": "tycoon_elastic_password_123",
    "IndexName": "tycoon-logs",
    "Enabled": true
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire",
    "WorkerCount": 10
  },
  "Analytics": {
    "Enabled": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:8080",
      "https://localhost:8080",
      "http://localhost:8200",
      "https://localhost:8200",
      "http://localhost:63033",
      "https://localhost:63033"
    ]
  },
  //"Auth": {
  //  "SecretKey": "uR4pLgITeJO5N0Sbj5XeGQh0hYzKKWtP",
  //  "JwtIssuer": "TycoonBackend",
  //  "JwtAudience": "TycoonClient",
  //  "AccessTokenExpirationMinutes": 60,
  //  "RefreshTokenExpirationDays": 30
  //},
  "JwtSettings": {
    "SecretKey": "YOUR-SUPER-SECRET-KEY-MINIMUM-32-CHARACTERS-LONG-FOR-SECURITY",
    "Issuer": "TycoonBackendApi",
    "Audience": "TycoonFrontendApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Iap": {
    "EnableStrictValidation": true,
    "AppleSharedSecret": "dev-apple-shared-secret-configured",
    "GooglePackageName": "com.tycoon.app.dev",
    "GoogleServiceAccountJsonPath": "/tmp/dev-google-service-account.json",
    "GoogleApiAccessToken": "__IAP_GOOGLE_API_ACCESS_TOKEN__"
  },
  "Stripe": {
    "Enabled": false,
    "SecretKey": "__STRIPE_SECRET_KEY__",
    "PublishableKey": "__STRIPE_PUBLISHABLE_KEY__",
    "WebhookSecret": "__STRIPE_WEBHOOK_SECRET__",
    "SuccessUrl": "https://localhost:3000/store/success?session_id={CHECKOUT_SESSION_ID}",
    "CancelUrl": "https://localhost:3000/store/cancel",
    "PortalReturnUrl": "https://localhost:3000/store/subscription",
    "AllowPromotionCodes": true,
    "AutomaticTax": false,
    "DefaultCurrency": "usd"
  },
  "PayPal": {
    "Enabled": false,
    "ClientId": "__PAYPAL_CLIENT_ID__",
    "ClientSecret": "__PAYPAL_CLIENT_SECRET__",
    "BaseUrl": "https://api-m.sandbox.paypal.com",
    "ReturnUrl": "https://localhost:3000/store/paypal/return",
    "CancelUrl": "https://localhost:3000/store/paypal/cancel",
    "BrandName": "Tycoon",
    "WebhookId": "__PAYPAL_WEBHOOK_ID__"
  },
  "Crypto": {
    "Enabled": true,
    "AllowedNetworks": [ "solana", "ethereum" ],
    "MinWithdrawalUnits": 1,
    "HotWalletAddress": "__CRYPTO_HOT_WALLET_ADDRESS__"
  },
  "SidecarInference": {
    "EnableQuestionDifficultyEstimator": false,
    "QuestionDifficultyUrl": "http://localhost:8000/ml/question-difficulty"
  },
  "MlModels": {
    "QuestionDifficultyUrl": "__ML_QUESTION_DIFFICULTY_URL__",
    "ChurnRiskUrl": "__ML_CHURN_RISK_URL__",
    "MatchQualityUrl": "__ML_MATCH_QUALITY_URL__",
    "ApiKey": "__ML_MODELS_API_KEY__"
  },
  "RateLimiting": {
    "Enabled": true,
    "MatchSubmit": {
      "PermitLimit": 10,
      "WindowSeconds": 10
    },
    "GlobalApi": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    }
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [
          "TycoonClient"
        ],
        "ValidIssuer": "dotnet-user-jwts"
      }
    }
  }
}
