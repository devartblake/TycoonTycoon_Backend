{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://+:5050" }
    }
  },
  "KmsApi": {
    "ServiceToken": ""
  },
  "Kms": {
    "Suites": {
      "// EnableHybridPq": "Post-quantum HybridPqV1 (X25519+ML-KEM-768). Off until it passes human crypto review and clients support it.",
      "EnableHybridPq": false
    }
  },
  "Jwt": {
    "Authority": "",
    "Audience": "kms-api"
  },
  "JwtSettings": {
    "SecretKey": ""
  },
  "Vault": {
    "Address": "http://localhost:8200",
    "Token": "",
    "TransitMount": "transit",
    "SessionWrapKey": "synaptix-session-wrap",
    "PayloadWrapKey": "synaptix-payload-wrap",
    "Required": false
  },
  "ConnectionStrings": {
    "cache": "",
    "redis": ""
  },
  "AllowedHosts": "*"
}
