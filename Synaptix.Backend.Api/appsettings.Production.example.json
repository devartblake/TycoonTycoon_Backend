{
  // =========================================================
  // Synaptix Backend — Production Configuration Template
  // Copy to appsettings.Production.json and fill in REPLACE
  // values, or inject as environment variables.
  // DO NOT commit files containing real secrets.
  // =========================================================

  "ConnectionStrings": {
    "db":            "Host=<REPLACE>;Port=5432;Database=synaptix_db;Username=synaptix_user;Password=<REPLACE>;SSL Mode=Require",
    "redis":         "redis.<REPLACE>:6379,password=<REPLACE>,defaultDatabase=0,ssl=true",
    "mongo":         "mongodb://synaptix_app_user:<REPLACE>@mongo.<REPLACE>:27017/synaptix_analytics?authSource=synaptix_analytics",
    "elasticsearch": "https://es.<REPLACE>:9200"
  },

  "Jwt": {
    "Issuer":    "SynaptixBackendApi",
    "Audience":  "SynaptixFrontendApp",
    "SecretKey": "<REPLACE — minimum 32 characters, generate with: openssl rand -base64 48>"
  },

  "MinIO": {
    "Endpoint":        "s3.<REPLACE>:443",
    "AccessKey":       "<REPLACE>",
    "SecretKey":       "<REPLACE>",
    "Bucket":          "synaptix-assets",
    "UseSSL":          true,
    "PublicEndpoint":  "https://cdn.<REPLACE>"
  },

  "Mongo": {
    "Database": "synaptix_analytics"
  },

  "Elastic": {
    "Url":                    "https://es.<REPLACE>:9200",
    "Username":               "elastic",
    "Password":               "<REPLACE>",
    "DailyReadAlias":         "synaptix-daily-rollups",
    "PlayerDailyReadAlias":   "synaptix-player-daily-rollups",
    "DailyWriteAlias":        "synaptix-daily-rollups-write",
    "PlayerDailyWriteAlias":  "synaptix-player-daily-rollups-write",
    "DailyInitialIndex":      "synaptix-daily-rollups-000001",
    "PlayerDailyInitialIndex":"synaptix-player-daily-rollups-000001"
  },

  "Observability": {
    "ServiceName":   "Synaptix.Backend.Api",
    "OtlpEndpoint":  "http://otel-collector.<REPLACE>:4317"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris":    "https://es.<REPLACE>:9200",
          "indexFormat": "synaptix-logs-{0:yyyy.MM.dd}",
          "username":    "elastic",
          "password":    "<REPLACE>"
        }
      }
    ]
  },

  "AdminAuth": {
    "AllowedEmails": [ "<REPLACE — production operator email>" ],
    "AllowTrustedBffPlainJson": false
  },

  "KmsClient": {
    "BaseUrl":      "https://kms.<REPLACE>",
    "ServiceToken": "<REPLACE>",
    "Required":     true
  },

  "Vault": {
    "Address":    "https://vault.<REPLACE>",
    "Token":      "<REPLACE>",
    "MountPath":  "transit",
    "KeyName":    "synaptix-backend"
  },

  "Hangfire": {
    "ConnectionString": "Host=<REPLACE>;Port=5432;Database=synaptix_db;Username=synaptix_user;Password=<REPLACE>;SSL Mode=Require"
  },

  "AppConfig": {
    "MinimumClientVersion": "1.0.0"
  }
}
