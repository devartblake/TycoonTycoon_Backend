{
  "ConnectionStrings": {
    "db": "Host=localhost;Port=5432;Database=synaptix_db;Username=synaptix_user;Password=synaptix_password_123",
    "redis": "localhost:6379,password=synaptix_redis_password_123,defaultDatabase=0",
    "mongo": "mongodb://synaptix_admin:synaptix_mongo_password_123@localhost:27017/synaptix_db?authSource=admin",
    "elasticsearch": "http://localhost:9200"
  },
  "Mongo": {
    "Database": "synaptix_analytics"
  },
  "Analytics": {
    "Enabled": true
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire",
    "WorkerCount": 10
  },
  //"Auth": {
  //  "JwtKey": "your-super-secret-jwt-key-change-me-in-production-minimum-32-characters-long",
  //  "JwtIssuer": "SynaptixBackend",
  //  "JwtAudience": "SynaptixClient",
  //  "AccessTokenExpirationMinutes": 60,
  //  "RefreshTokenExpirationDays": 30
  //},
  "JwtSettings": {
    "SecretKey": "YOUR-SUPER-SECRET-KEY-MINIMUM-32-CHARACTERS-LONG-FOR-SECURITY",
    "Issuer": "SynaptixBackendApi",
    "Audience": "SynaptixFrontendApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Iap": {
    "EnableStrictValidation": false,
    "AppleSharedSecret": "__IAP_APPLE_SHARED_SECRET__",
    "GooglePackageName": "__IAP_GOOGLE_PACKAGE_NAME__",
    "GoogleServiceAccountJsonPath": "__IAP_GOOGLE_SERVICE_ACCOUNT_JSON_PATH__",
    "GoogleApiAccessToken": "__IAP_GOOGLE_API_ACCESS_TOKEN__"
  },
  "Stripe": {
    "Enabled": false,
    "SecretKey": "__STRIPE_SECRET_KEY__",
    "PublishableKey": "__STRIPE_PUBLISHABLE_KEY__",
    "WebhookSecret": "__STRIPE_WEBHOOK_SECRET__",
    "SuccessUrl": "https://localhost:3000/store/success?session_id={CHECKOUT_SESSION_ID}",
    "CancelUrl": "https://localhost:3000/store/cancel",
    "PortalReturnUrl": "https://localhost:3000/store/subscription",
    "AllowPromotionCodes": true,
    "AutomaticTax": false,
    "DefaultCurrency": "usd"
  },
  "PayPal": {
    "Enabled": false,
    "ClientId": "__PAYPAL_CLIENT_ID__",
    "ClientSecret": "__PAYPAL_CLIENT_SECRET__",
    "BaseUrl": "https://api-m.sandbox.paypal.com",
    "ReturnUrl": "https://localhost:3000/store/paypal/return",
    "CancelUrl": "https://localhost:3000/store/paypal/cancel",
    "BrandName": "Tycoon",
    "WebhookId": "__PAYPAL_WEBHOOK_ID__"
  },
  "Crypto": {
    "Enabled": true,
    "AllowedNetworks": [ "solana", "ethereum" ],
    "MinWithdrawalUnits": 1,
    "HotWalletAddress": "__CRYPTO_HOT_WALLET_ADDRESS__"
  },
  "SidecarInference": {
    "EnableQuestionDifficultyEstimator": false,
    "QuestionDifficultyUrl": "http://localhost:8000/ml/question-difficulty"
  },
  "MlModels": {
    "QuestionDifficultyUrl": "__ML_QUESTION_DIFFICULTY_URL__",
    "ChurnRiskUrl": "__ML_CHURN_RISK_URL__",
    "MatchQualityUrl": "__ML_MATCH_QUALITY_URL__",
    "ApiKey": "__ML_MODELS_API_KEY__"
  },
  "Elastic": {
    "Url": "http://localhost:9200",
    "DailyWriteAlias": "synaptix-daily-rollups",
    "PlayerDailyWriteAlias": "synaptix-player-daily-rollups"
  },
  "AdminOps": {
    "Enabled": true,
    "Header": "X-Admin-Ops-Key",
    "Key": "CHANGE_ME"
  },
  "AdminAuth": {
    "AllowTrustedBffPlainJson": true
  },
  "Observability": {
    "ServiceName": "Synaptix.Backend.Api",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning",
      "Hangfire": "Information"
    }
  }
}
