# Development Dockerfile with HMR support

FROM node:22-alpine

WORKDIR /app

# Install pnpm for faster installs (optional, can use npm)
# RUN npm i -g pnpm

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose dev server port
EXPOSE 5173

# Expose additional ports for debugging, etc.
EXPOSE 9229

# Run dev server with HMR enabled
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
