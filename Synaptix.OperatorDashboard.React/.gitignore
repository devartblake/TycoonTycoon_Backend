# Dependencies
node_modules/

# Build output (rebuilt by Vite / the Docker image; never commit)
dist/

# Test & coverage artifacts
coverage/
playwright-report/
test-results/
.vitest/

# Compiled JS emitted next to TS sources (should never be committed)
# The build uses `tsc --noEmit`; this guards against a stray bare `tsc`.
src/**/*.js
!src/**/*.config.js

# Local env & editor
.env.local
.env.*.local
*.local
.DS_Store
