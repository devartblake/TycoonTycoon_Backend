# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/account/dsn/
# Leave empty for development (logs to console only)
VITE_SENTRY_DSN=

# API Configuration
# Leave empty (same-origin): /admin calls go through the Vite dev proxy /
# Docker nginx proxy, which inject the required X-Admin-Ops-Key header.
# Pointing this directly at the API bypasses the proxy and every call 401s.
VITE_API_BASE_URL=
VITE_ENABLE_MOCK_MODE=true

# Experimental / incomplete admin UIs (default off — no backend routes yet)
# VITE_ENABLE_INSTALLER=true
# VITE_ENABLE_DIAGNOSTICS=true

# Environment
VITE_ENV=development
