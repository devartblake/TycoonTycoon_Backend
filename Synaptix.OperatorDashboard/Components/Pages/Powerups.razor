@page "/powerups"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth
@using System.Text.Json

<h1>Powerups</h1>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else
{

<div class="tabs">
    @foreach (var tab in new[] { "Lookup", "Grant" })
    {
        <button class="tab @(_tab == tab ? "active" : "")" @onclick="() => _tab = tab">@tab</button>
    }
</div>

@if (_tab == "Lookup")
{
    <div class="card">
        <h2>Player Powerup State</h2>
        <div class="filters">
            <input @bind="_lookupPlayerId" placeholder="Player ID (UUID)..." style="width:340px" />
            <button @onclick="LookupAsync">Search</button>
        </div>

        @if (_inventory is not null)
        {
            @* PowerupStateDto: { playerId, powerups: [{ type, quantity, cooldownUntilUtc }] } *@
            var root = _inventory.RootElement;
            @if (root.TryGetProperty("powerups", out var powerups) && powerups.GetArrayLength() > 0)
            {
                <table>
                    <thead><tr><th>Type</th><th>Quantity</th><th>Cooldown Until (UTC)</th></tr></thead>
                    <tbody>
                        @foreach (var el in powerups.EnumerateArray())
                        {
                            var type     = el.TryGetProperty("type",            out var t) ? t.GetString() ?? "—" : "—";
                            var quantity = el.TryGetProperty("quantity",         out var q) ? q.GetInt32().ToString() : "—";
                            var cooldown = el.TryGetProperty("cooldownUntilUtc", out var c) && c.ValueKind != JsonValueKind.Null
                                           ? c.GetString() ?? "none" : "none";
                            <tr>
                                <td>@type</td>
                                <td>@quantity</td>
                                <td>@cooldown</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color:#64748b;font-size:.875rem">No powerups found for this player.</p>
            }
        }

        @if (!string.IsNullOrEmpty(_lookupMsg))
        {
            <p class="message @(_lookupError ? "error-msg" : "")">@_lookupMsg</p>
        }
    </div>
}

@if (_tab == "Grant")
{
    <div class="card">
        <h2>Grant Powerup</h2>
        <label>Player ID<input @bind="_grantPlayerId" placeholder="UUID..." /></label>
        <label>Event ID (context)<input @bind="_grantEventId" placeholder="UUID..." /></label>
        <label>Powerup Type
            <select @bind="_grantType">
                <option value="FiftyFifty">50/50</option>
                <option value="Skip">Skip</option>
                <option value="DoublePoints">Double Points</option>
                <option value="ExtraTime">Extra Time</option>
            </select>
        </label>
        <label>Quantity<input type="number" @bind="_grantQuantity" min="1" max="100" /></label>
        <label>Reason<input @bind="_grantReason" placeholder="e.g. compensation, promo" /></label>
        <button @onclick="GrantAsync" style="margin-top:.5rem">Grant</button>
        @if (!string.IsNullOrEmpty(_grantMsg))
        {
            <p class="message @(_grantError ? "error-msg" : "")">@_grantMsg</p>
        }
    </div>
}

} @* close auth-failed else *@

@code {
    private string _tab = "Lookup";
    private bool _authFailed;
    private string _lookupPlayerId = string.Empty;
    private JsonDocument? _inventory;
    private string _lookupMsg = string.Empty;
    private bool _lookupError;

    private string _grantPlayerId = string.Empty;
    private string _grantEventId = string.Empty;
    private string _grantType = "FiftyFifty";
    private int _grantQuantity = 1;
    private string _grantReason = string.Empty;
    private string _grantMsg = string.Empty;
    private bool _grantError;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; }
    }

    private async Task LookupAsync()
    {
        _lookupMsg = string.Empty;
        _lookupError = false;
        _inventory = null;
        if (!Guid.TryParse(_lookupPlayerId, out var id)) { _lookupMsg = "Invalid player ID."; _lookupError = true; return; }
        _inventory = await Api.GetPlayerPowerupsAsync(id);
        if (_inventory is null) { _lookupMsg = "Player not found or API error."; _lookupError = true; return; }
    }

    private async Task GrantAsync()
    {
        _grantMsg = string.Empty;
        _grantError = false;
        if (!Guid.TryParse(_grantPlayerId, out var playerId)) { _grantMsg = "Invalid player ID."; _grantError = true; return; }
        if (!Guid.TryParse(_grantEventId, out var eventId)) { _grantMsg = "Invalid event ID."; _grantError = true; return; }
        if (string.IsNullOrWhiteSpace(_grantReason)) { _grantMsg = "Reason is required."; _grantError = true; return; }

        // Body matches GrantPowerupRequest(EventId, PlayerId, Type, Quantity, Reason)
        var ok = await Api.GrantPowerupAsync(new
        {
            eventId,
            playerId,
            type = _grantType,
            quantity = _grantQuantity,
            reason = _grantReason
        });
        _grantMsg = ok ? "Powerup granted." : "Grant failed — check API logs.";
        _grantError = !ok;
    }
}

<style>
    .tabs { display:flex; gap:.5rem; margin-bottom:1.25rem; }
    .tab { background:#e2e8f0; color:#475569; }
    .tab.active { background:#3b82f6; color:#fff; }
    label { display:flex; flex-direction:column; gap:.25rem; font-size:.875rem; color:#475569; margin-bottom:.6rem; }
    label input, label select { padding:.4rem .6rem; border:1px solid #cbd5e1; border-radius:6px; font-size:.875rem; }
    .error-msg { background:#fef2f2; border-left:3px solid #ef4444; color:#991b1b; padding:.5rem .75rem; border-radius:4px; }
    .message { margin-top:.75rem; }
</style>
