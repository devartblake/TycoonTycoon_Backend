@page "/audit"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth
@using Synaptix.OperatorDashboard.Components.Common

<h1>Security Audit Log</h1>

<div class="filters">
    <label style="flex-direction:row;align-items:center;gap:.4rem;font-size:.875rem;color:#475569">
        From <input type="date" @bind="_from" />
    </label>
    <label style="flex-direction:row;align-items:center;gap:.4rem;font-size:.875rem;color:#475569">
        To <input type="date" @bind="_to" />
    </label>
    <select @bind="_status">
        <option value="">All statuses</option>
        <option value="success">Success</option>
        <option value="error">Error</option>
        <option value="forbidden">Forbidden</option>
    </select>
    <button @onclick="LoadAsync">Search</button>
</div>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else if (_doc is null) { <p>Loading...</p> }
else
{
    <table>
        <thead><tr><th>Timestamp</th><th>Admin</th><th>Operation</th><th>Status</th><th>IP</th></tr></thead>
        <tbody>
            @foreach (var el in JsonSafe.EnumerateArrayProperty(_doc, "items"))
            {
                var ts      = JsonSafe.GetText(el, "timestamp");
                var admin   = JsonSafe.GetText(el, "adminEmail");
                var op      = JsonSafe.GetText(el, "operation");
                var stat    = JsonSafe.GetText(el, "status");
                var ip      = JsonSafe.GetText(el, "ipAddress");
                <tr>
                    <td>@ts</td>
                    <td>@admin</td>
                    <td><code>@op</code></td>
                    <td><span class="badge @StatusClass(stat)">@stat</span></td>
                    <td>@ip</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pager">
        <button @onclick="PrevPage" disabled="@(_page <= 1)">← Prev</button>
        <span>Page @_page</span>
        <button @onclick="NextPage">Next →</button>
    </div>
}

@code {
    private JsonDocument? _doc;
    private bool _authFailed;
    private DateTime? _from, _to;
    private string _status = string.Empty;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        DateTimeOffset? from = _from.HasValue ? new DateTimeOffset(_from.Value, TimeSpan.Zero) : null;
        DateTimeOffset? to   = _to.HasValue   ? new DateTimeOffset(_to.Value,   TimeSpan.Zero) : null;
        _doc = await Api.GetSecurityAuditAsync(from, to, string.IsNullOrEmpty(_status) ? null : _status, _page);
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private static string StatusClass(string s) => s switch
    {
        "success"   => "on",
        "forbidden" => "off",
        _           => ""
    };
}

<style>
    .pager { display:flex; gap:.75rem; align-items:center; margin-top:1rem; }
    label { display:flex; gap:.4rem; align-items:center; font-size:.875rem; color:#475569; }
</style>
