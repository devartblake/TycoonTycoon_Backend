@page "/users"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth
@using Synaptix.OperatorDashboard.Components.Common

<h1>Users</h1>

<div class="filters">
    <input @bind="_query" placeholder="Search by name or email" />
    <label><input type="checkbox" @bind="_bannedOnly" /> Banned only</label>
    <button @onclick="LoadAsync">Search</button>
</div>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else if (_doc is null)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead><tr><th>ID</th><th>Handle</th><th>Email</th><th>Banned</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var el in JsonSafe.EnumerateArrayProperty(_doc, "items"))
            {
                var userId  = JsonSafe.GetText(el, "id", string.Empty);
                var handle  = JsonSafe.GetText(el, "handle");
                var email   = JsonSafe.GetText(el, "email");
                var banned  = JsonSafe.GetBool(el, "isBanned");
                <tr>
                    <td><code>@userId[..Math.Min(8, userId.Length)]…</code></td>
                    <td>@handle</td>
                    <td>@email</td>
                    <td>@(banned ? "Yes" : "No")</td>
                    <td>
                        @if (CanWrite)
                        {
                            @if (!banned)
                            {
                                @if (_confirmBanId == userId)
                                {
                                    <span style="font-size:.8rem;color:#dc2626;margin-right:.4rem">Ban user?</span>
                                    <button class="danger" @onclick="() => ConfirmBanAsync(userId)">Yes, ban</button>
                                    <button @onclick="() => _confirmBanId = null" style="margin-left:.25rem;background:#94a3b8">Cancel</button>
                                }
                                else
                                {
                                    <button class="danger" @onclick="() => _confirmBanId = userId">Ban</button>
                                }
                            }
                            else
                            {
                                <button @onclick="() => UnbanAsync(userId)">Unban</button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="message">@_message</p>
    }
}

@code {
    [CascadingParameter(Name = "Perms")] private HashSet<string> Perms { get; set; } = [];
    private bool CanWrite => Perms.Contains("users:write");

    private JsonDocument? _doc;
    private bool _authFailed;
    private string _query = string.Empty;
    private bool _bannedOnly;
    private string _message = string.Empty;
    private string? _confirmBanId;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _doc = await Api.ListUsersAsync(_query, _bannedOnly ? true : null);
    }

    private async Task ConfirmBanAsync(string userId)
    {
        _confirmBanId = null;
        _message = string.Empty;
        var ok = await Api.BanUserAsync(userId, "Banned via operator dashboard");
        _message = ok ? "User banned." : "Ban failed.";
        await LoadAsync();
    }

    private async Task UnbanAsync(string userId)
    {
        _message = string.Empty;
        var ok = await Api.UnbanUserAsync(userId);
        _message = ok ? "User unbanned." : "Unban failed.";
        await LoadAsync();
    }
}
