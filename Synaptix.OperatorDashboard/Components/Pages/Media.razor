@page "/media"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth

<h1>Media Upload</h1>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else
{

<div class="card">
    <h2>Upload Asset</h2>
    <p style="font-size:.875rem;color:#64748b;margin-bottom:1rem">
        Select a file to upload. The system generates a stable asset key via the upload intent endpoint,
        then stores the file in MinIO and returns a public URL.
    </p>

    <label>
        File
        <InputFile OnChange="OnFileChanged" accept="image/*,video/*,application/octet-stream" />
    </label>

    @if (_file is not null)
    {
        <div class="file-info">
            <span>@_file.Name</span>
            <span class="file-size">@FormatSize(_file.Size)</span>
            <span class="file-type">@_file.ContentType</span>
        </div>
    }

    <button @onclick="UploadAsync"
            disabled="@(_uploading || _file is null)"
            style="margin-top:1rem">
        @if (_uploading)
        {
            <span class="spinner"></span>
            <span>@_uploadStatus</span>
        }
        else
        {
            <span>Upload</span>
        }
    </button>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="message @(_isError ? "error-msg" : "success-msg")">@_message</p>
    }

    @if (_resultUrl is not null)
    {
        <div class="result-box">
            <div class="result-row">
                <span class="result-label">Asset Key</span>
                <code>@_resultAssetKey</code>
            </div>
            <div class="result-row">
                <span class="result-label">Public URL</span>
                <a href="@_resultUrl" target="_blank">@_resultUrl</a>
            </div>
        </div>
    }
</div>

<div class="card" style="margin-top:1.5rem">
    <h2>Get Upload Intent</h2>
    <p style="font-size:.875rem;color:#64748b;margin-bottom:.75rem">
        Request a pre-signed asset key and upload URL from the API before uploading. Useful when you
        need to hand the upload URL to a client or external process.
    </p>

    <label>File Name<input @bind="_intentFileName" placeholder="e.g. avatar.png" /></label>
    <label>Content Type<input @bind="_intentContentType" placeholder="e.g. image/png" /></label>
    <label>Size (bytes)<input type="number" @bind="_intentSizeBytes" min="1" /></label>

    <button @onclick="GetIntentAsync" style="margin-top:.5rem">Get Intent</button>

    @if (_intent is not null)
    {
        <div class="result-box" style="margin-top:.75rem">
            <div class="result-row"><span class="result-label">Asset Key</span><code>@_intentAssetKey</code></div>
            <div class="result-row"><span class="result-label">Upload URL</span><code style="word-break:break-all;font-size:.75rem">@_intentUploadUrl</code></div>
            <div class="result-row"><span class="result-label">Expires</span><span>@_intentExpires</span></div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_intentMessage))
    {
        <p class="message error-msg">@_intentMessage</p>
    }
</div>

} @* close auth-failed else *@

@code {
    private IBrowserFile? _file;
    private string _message = string.Empty;
    private string? _resultUrl;
    private string _resultAssetKey = string.Empty;
    private bool _uploading;
    private bool _isError;
    private bool _authFailed;
    private string _uploadStatus = string.Empty;

    private string _intentFileName = string.Empty;
    private string _intentContentType = "image/png";
    private long _intentSizeBytes = 0;
    private JsonDocument? _intent;
    private string _intentAssetKey = string.Empty;
    private string _intentUploadUrl = string.Empty;
    private string _intentExpires = string.Empty;
    private string _intentMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; }
    }

    private void OnFileChanged(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _resultUrl = null;
        _message = string.Empty;
        // Pre-fill intent form from selected file
        _intentFileName = _file.Name;
        _intentContentType = string.IsNullOrEmpty(_file.ContentType) ? "application/octet-stream" : _file.ContentType;
        _intentSizeBytes = _file.Size;
    }

    private async Task UploadAsync()
    {
        if (_file is null) return;
        _uploading = true;
        _message = string.Empty;
        _resultUrl = null;
        _isError = false;

        try
        {
            // Step 1: Get upload intent
            _uploadStatus = "Getting upload intent…";
            StateHasChanged();
            var ct = CancellationToken.None;
            var intentDoc = await Api.GetMediaIntentAsync(_file.Name, _file.ContentType, _file.Size, ct);
            if (intentDoc is null)
            {
                _message = "Failed to get upload intent — check API logs.";
                _isError = true;
                return;
            }

            var root = intentDoc.RootElement;
            var uploadUrl = root.TryGetProperty("uploadUrl", out var u) ? u.GetString() : null;
            _resultAssetKey = root.TryGetProperty("assetKey", out var k) ? k.GetString() ?? string.Empty : string.Empty;

            if (string.IsNullOrEmpty(uploadUrl))
            {
                _message = "Intent response missing upload URL.";
                _isError = true;
                return;
            }

            // Step 2: Upload file to the intent URL
            _uploadStatus = "Uploading file…";
            StateHasChanged();
            await using var stream = _file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var result = await Api.UploadMediaAsync(uploadUrl, stream, _file.ContentType, _file.Name, ct);
            if (result is null)
            {
                _message = "Upload failed — check API logs.";
                _isError = true;
                return;
            }

            if (result.RootElement.TryGetProperty("url", out var urlProp))
                _resultUrl = urlProp.GetString();
            _message = "Upload successful.";
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _uploading = false;
            _uploadStatus = string.Empty;
        }
    }

    private async Task GetIntentAsync()
    {
        _intentMessage = string.Empty;
        _intent = null;
        if (string.IsNullOrWhiteSpace(_intentFileName)) { _intentMessage = "File name is required."; return; }
        if (_intentSizeBytes <= 0) { _intentMessage = "Size must be greater than 0."; return; }

        _intent = await Api.GetMediaIntentAsync(_intentFileName, _intentContentType, _intentSizeBytes);
        if (_intent is null) { _intentMessage = "Intent request failed — check API logs."; return; }

        var root = _intent.RootElement;
        _intentAssetKey  = root.TryGetProperty("assetKey",   out var k) ? k.GetString() ?? string.Empty : string.Empty;
        _intentUploadUrl = root.TryGetProperty("uploadUrl",   out var u) ? u.GetString() ?? string.Empty : string.Empty;
        _intentExpires   = root.TryGetProperty("expiresAtUtc", out var e) ? e.GetString() ?? string.Empty : string.Empty;
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        _ when bytes < 1024 => $"{bytes} B",
        _ when bytes < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024):F1} MB"
    };
}

<style>
    label { display:flex; flex-direction:column; gap:.25rem; font-size:.875rem; color:#475569; margin-bottom:.6rem; }
    label input { padding:.4rem .6rem; border:1px solid #cbd5e1; border-radius:6px; font-size:.875rem; }
    .error-msg { background:#fef2f2; border-left-color:#ef4444; color:#991b1b; }
    .success-msg { background:#f0fdf4; border-left-color:#22c55e; color:#166534; }
    button:disabled { opacity:.5; cursor:not-allowed; }
    .file-info { display:flex; gap:.75rem; align-items:center; margin:.5rem 0; padding:.5rem .75rem;
        background:#f8fafc; border-radius:6px; font-size:.875rem; }
    .file-size, .file-type { color:#64748b; font-size:.8rem; }
    .spinner { display:inline-block; width:14px; height:14px; border:2px solid rgba(255,255,255,.4);
        border-top-color:#fff; border-radius:50%; animation:spin .7s linear infinite; margin-right:.5rem; }
    @@keyframes spin { to { transform:rotate(360deg); } }
    .result-box { margin-top:.75rem; padding:.75rem 1rem; background:#f8fafc; border:1px solid #e2e8f0;
        border-radius:8px; display:flex; flex-direction:column; gap:.5rem; }
    .result-row { display:flex; gap:.75rem; align-items:baseline; font-size:.875rem; }
    .result-label { color:#64748b; min-width:80px; font-size:.8rem; }
    .result-row a { color:#3b82f6; word-break:break-all; }
    .result-row code { background:#e2e8f0; padding:.1rem .4rem; border-radius:4px; font-size:.8rem; word-break:break-all; }
</style>
