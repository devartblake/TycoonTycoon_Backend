# =============================================================================
# Tycoon Backend - Docker Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize values for your environment:
#   cp docker/.env.example docker/.env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=synaptix_db
POSTGRES_USER=synaptix_user
POSTGRES_PASSWORD=synaptix_password_123
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=synaptix_admin
MONGO_INITDB_ROOT_PASSWORD=synaptix_mongo_password_123
MONGO_INITDB_DATABASE=synaptix_db
MONGO_PORT=27017
MONGO_APP_USER=synaptix_app_user
MONGO_APP_PASSWORD=synaptix_app_password_123
MONGO_APP_DB=synaptix_db

# --- Redis ---
REDIS_PASSWORD=synaptix_redis_password_123
REDIS_PORT=6379

# --- Elasticsearch / Kibana ---
ELASTIC_PASSWORD=synaptix_elastic_password_123
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- RabbitMQ ---
RABBITMQ_USER=synaptix_user
RABBITMQ_PASSWORD=synaptix_rabbitmq_password_123
RABBITMQ_VHOST=tycoon
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- MinIO ---
MINIO_ROOT_USER=synaptix_minio_user
MINIO_ROOT_PASSWORD=synaptix_minio_password_123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Optional Admin UIs (dev profile) ---
PGADMIN_DEFAULT_EMAIL=admin@tycoon.local
PGADMIN_DEFAULT_PASSWORD=admin_password_123
PGADMIN_PORT=5050
MONGO_EXPRESS_PORT=8081
DBGATE_PORT=3001
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin_password_123
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_password_123

# --- Backend API ---
ASPNETCORE_ENVIRONMENT=Development
BUILD_CONFIGURATION=Debug
MIGRATION_ALLOW_ENSURE_CREATED=true
MIGRATION_RESET_DATABASE=true
BACKEND_HTTP_PORT=5000
BACKEND_GRPC_PORT=5001
HANGFIRE_ENABLED=true
ANALYTICS_ENABLED=true
ADMIN_OPS_ENABLED=true
ADMIN_OPS_KEY=CHANGE_ME_IN_PRODUCTION
ADMIN_AUTH_ALLOW_TRUSTED_BFF_PLAIN_JSON=true
ADMIN_AUTH_TRANSPORT=auto
KMS_API_BASE_URL=
KMS_SERVICE_TOKEN=
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production-minimum-32-characters-long

# Browser CORS origins (set for Flutter Web or any browser client)
CORS_ORIGIN_0=http://localhost:63033
CORS_ORIGIN_1=http://127.0.0.1:63033
CORS_ORIGIN_2=http://localhost:8200
CORS_ORIGIN_3=http://localhost:3000
CORS_ORIGIN_4=http://localhost:8080

# --- Migration Service ---
MIGRATION_MODE=MigrateAndSeed
REBUILD_ELASTIC=false
REBUILD_ELASTIC_FROM_DATE=2025-01-01
REBUILD_ELASTIC_TO_DATE=2025-12-31

# --- Super Admin Account ---
SUPER_ADMIN_EMAIL=admin@tycoon.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_HANDLE=superadmin

# --- Logging ---
LOG_LEVEL=Information

# --- Traefik Reverse Proxy ---
# Dev: Traefik listens on port 80 (dashboard on 8080). Direct service ports remain accessible as fallback.
# Prod: Set DOMAIN and ACME_EMAIL; Traefik handles HTTPS via Let's Encrypt.
#   Run with: docker compose -f docker/compose.yml -f docker/compose.prod.yml up -d
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
# Production-only — required when using compose.prod.yml:
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com
# --- Cloudflare Tunnel (optional) ---
# Used by docker/compose.cloudflare-tunnel.yml
CLOUDFLARE_TUNNEL_TOKEN=
