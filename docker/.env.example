# =============================================================================
# Synaptix Backend - Docker Environment Configuration Template
# =============================================================================
# DO NOT put real secrets in this file. It is tracked in git.
#
# QUICK START (local dev):
#   dotnet run --project Synaptix.Setup -- init-local
#   This generates docker/.env with strong random secrets.
#
# MANUAL:
#   cp docker/.env.example docker/.env
#   Then replace all <generated-by-synaptix-setup> values with real secrets.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=synaptix_db
POSTGRES_USER=synaptix_user
POSTGRES_PASSWORD=<generated-by-synaptix-setup>
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=synaptix_admin
MONGO_INITDB_ROOT_PASSWORD=<generated-by-synaptix-setup>
MONGO_INITDB_DATABASE=synaptix_analytics
MONGO_PORT=27017
MONGO_APP_USER=synaptix_app_user
MONGO_APP_PASSWORD=<generated-by-synaptix-setup>
MONGO_APP_DB=synaptix_analytics
MONGO_AUTH_DB=synaptix_analytics
MONGO_ANALYTICS_DB=synaptix_analytics
MONGO_CRYPTO_DB=synaptix_crypto
SETUP_MONGO_REMOVE_LEGACY_ADMIN_APP_USER=false

# MongoDB Crypto-Service User (optional: separate credentials for crypto-service isolation)
# If not specified, crypto-service will use MONGO_APP_USER credentials
MONGO_CRYPTO_USER=synaptix_crypto_svc
MONGO_CRYPTO_PASSWORD=<generate-strong-random-password>

# MongoDB connection URLs
MONGO_URL=mongodb://<MONGO_APP_USER>:<MONGO_APP_PASSWORD>@mongodb:27017/<MONGO_ANALYTICS_DB>?authSource=<MONGO_AUTH_DB>
MONGO_CRYPTO_URL=mongodb://<MONGO_CRYPTO_USER>:<MONGO_CRYPTO_PASSWORD>@mongodb:27017/<MONGO_CRYPTO_DB>?authSource=<MONGO_AUTH_DB>

# --- Redis ---
REDIS_PASSWORD=<generated-by-synaptix-setup>
REDIS_PORT=6379

# --- Elasticsearch / Kibana ---
ELASTIC_PASSWORD=<generated-by-synaptix-setup>
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- RabbitMQ ---
RABBITMQ_USER=synaptix_user
RABBITMQ_PASSWORD=<generated-by-synaptix-setup>
RABBITMQ_VHOST=synaptix
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- MinIO ---
MINIO_ROOT_USER=synaptix_minio_user
MINIO_ROOT_PASSWORD=<generated-by-synaptix-setup>
MINIO_BUCKET=synaptix-assets
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SEED_STORE_ITEMS_KEY=seeds/store-items.json
MINIO_SEED_SKILL_NODES_KEY=seeds/skill-nodes.json
MINIO_SEED_SEASON_REWARDS_KEY=seeds/season-rewards.json
MINIO_SEED_QUESTIONS_KEY=seeds/questions.json

# --- Linode Object Storage (production S3-compatible storage) ---
# Example endpoint shape: us-east-1.linodeobjects.com
LINODE_OBJECT_STORAGE_ENDPOINT=<linode-region>.linodeobjects.com
LINODE_OBJECT_STORAGE_PUBLIC_ENDPOINT=<linode-region>.linodeobjects.com
LINODE_OBJECT_STORAGE_ACCESS_KEY=<linode-object-storage-access-key>
LINODE_OBJECT_STORAGE_SECRET_KEY=<linode-object-storage-secret-key>
LINODE_OBJECT_STORAGE_BUCKET=synaptix-assets

# --- Optional Admin UIs (dev profile) ---
PGADMIN_DEFAULT_EMAIL=admin@synaptix.app
PGADMIN_DEFAULT_PASSWORD=<generated-by-synaptix-setup>
PGADMIN_PORT=5050
MONGO_EXPRESS_PORT=8081
DBGATE_PORT=3001
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=<generated-by-synaptix-setup>
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=<generated-by-synaptix-setup>

# --- Backend API ---
ASPNETCORE_ENVIRONMENT=Development
BUILD_CONFIGURATION=Debug
# WARNING: Only enable in local development. Never set true in staging/production.
MIGRATION_ALLOW_ENSURE_CREATED=false
MIGRATION_RESET_DATABASE=false
BACKEND_HTTP_PORT=5000
BACKEND_GRPC_PORT=5001
CRYPTO_SERVICE_JWT=
CRYPTO_SERVICE_JWT_FILE=
REQUIRE_CRYPTO_SERVICE_JWT=false
HANGFIRE_ENABLED=true
ANALYTICS_ENABLED=true
ADMIN_OPS_ENABLED=true
# REQUIRED: Must be changed from placeholder before first run. Never use default in production.
ADMIN_OPS_KEY=<generated-by-synaptix-setup>
ADMIN_AUTH_ALLOW_TRUSTED_BFF_PLAIN_JSON=true
ADMIN_AUTH_TRANSPORT=auto
KMS_API_BASE_URL=http://kms-api:5050
KMS_SERVICE_TOKEN=<generated-by-synaptix-setup>
KMS_CLIENT_REQUIRED=false
COMPLIANCE_API_BASE_URL=http://compliance-api:5070
COMPLIANCE_API_PORT=5070
COMPLIANCE_SERVICE_TOKEN=<generated-by-synaptix-setup>
COMPLIANCE_CLIENT_REQUIRED=false
COMPLIANCE_DB_URL=
# REQUIRED: Minimum 32 characters. Must be unique per environment.
JWT_SECRET_KEY=<generated-by-synaptix-setup>

# Browser CORS origins (set for Flutter Web or any browser client)
CORS_ORIGIN_0=http://localhost:63033
CORS_ORIGIN_1=http://127.0.0.1:63033
CORS_ORIGIN_2=http://localhost:8200
CORS_ORIGIN_3=http://localhost:3000
CORS_ORIGIN_4=http://localhost:8080

# --- React Operator Dashboard ---
# Configuration for the next-gen React-based operator dashboard
REACT_API_BASE_URL=http://backend-api:5000
REACT_APP_ENV=development
REACT_DASHBOARD_PORT=8300

# --- Migration Service ---
MIGRATION_MODE=MigrateAndSeed
MIGRATION_SEED_SOURCE=Auto
MIGRATION_DASHBOARD_READINESS_ENABLED=true
MIGRATION_DASHBOARD_READINESS_STRICT=true
REBUILD_ELASTIC=false
REBUILD_ELASTIC_FROM_DATE=2025-01-01
REBUILD_ELASTIC_TO_DATE=2025-12-31

# --- Super Admin Account ---
SUPER_ADMIN_EMAIL=admin@tycoon.local
# REQUIRED: Must be changed before first run. Generated by: dotnet run --project Synaptix.Setup -- create-super-admin --local
SUPER_ADMIN_PASSWORD=<generated-by-synaptix-setup>
SUPER_ADMIN_HANDLE=superadmin

# --- Logging ---
LOG_LEVEL=Information

# --- Traefik Reverse Proxy ---
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com
CLOUDFLARE_TUNNEL_TOKEN=

# --- Production KMS / Vault ---
# For single-Linode prod, KMS is internal-only and Vault is not published publicly.
# Initialize/unseal Vault on the Linode, enable transit, create the keys below, then set VAULT_TOKEN.
VAULT_TOKEN=<vault-token-with-transit-access>
VAULT_TRANSIT_MOUNT=transit
VAULT_SESSION_WRAP_KEY=synaptix-session-wrap
VAULT_PAYLOAD_WRAP_KEY=synaptix-payload-wrap

# --- Slack Alerts ---
# Slack webhook URL for AlertManager notifications
# Get from: https://api.slack.com/apps -> Your App -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
