{
  "ConnectionStrings": {
    "db": "Host=localhost;Port=5432;Database=synaptix_db;Username=synaptix_user;Password=synaptix_password_123",
    "mongo": "mongodb://synaptix_admin:synaptix_mongo_password_123@localhost:27017/synaptix_db?authSource=synaptix_db",
    "redis": "localhost:6379,password=synaptix_redis_password_123",
    "elasticsearch": "http://localhost:9200"
  },
  "Observability": {
    "ServiceName": "Synaptix.MigrationService",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "MongoSettings": {
    "Database": "synaptix_analytics",
    "Collection": "posts"
  },
  "MigrationService": {
    "Mode": "MigrateAndSeed",
    "SeedSource": "Auto",
    "ResetDatabase": false,
    "AllowEnsureCreated": false,
    "DashboardReadiness": {
      "Enabled": true,
      "Strict": true
    },
    "RebuildElastic": {
      "Enabled": false,
      "FromUtcDate": null,
      "ToUtcDate": null
    }
  }
}
