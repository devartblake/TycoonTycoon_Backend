@page "/flags"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth

<h1>Feature Flags</h1>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else if (_flags is null)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead><tr><th>Flag</th><th>Enabled</th><th></th></tr></thead>
        <tbody>
            @foreach (var (key, val) in _flags)
            {
                <tr>
                    <td><code>@key</code></td>
                    <td><span class="badge @(val ? "on" : "off")">@(val ? "ON" : "OFF")</span></td>
                    <td>
                        <button @onclick="() => ToggleAsync(key, val)">
                            @(val ? "Disable" : "Enable")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="message">@_message</p>
    }
}

@code {
    private Dictionary<string, bool>? _flags;
    private bool _authFailed;
    private string _message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var config = await Api.GetConfigAsync();
        _flags = config?.FeatureFlags ?? [];
    }

    private async Task ToggleAsync(string key, bool current)
    {
        _message = string.Empty;
        var ok = await Api.PatchFlagsAsync(new Dictionary<string, bool> { [key] = !current });
        _message = ok ? $"{key} set to {!current}" : "Update failed.";
        await LoadAsync();
    }
}
