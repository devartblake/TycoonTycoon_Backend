@page "/notifications"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth

<h1>Notifications</h1>

<div class="tabs">
    @foreach (var tab in new[] { "Send", "Scheduled", "Templates", "History", "Dead Letter" })
    {
        <button class="tab @(_tab == tab ? "active" : "")" @onclick="() => SwitchTab(tab)">@tab</button>
    }
</div>

@if (_tab == "Send")
{
    <div class="card">
        <h2>Send Notification</h2>
        <label>Channel
            <select @bind="_sendChannel">
                <option value="">— select channel —</option>
                @if (_channels is not null)
                {
                    @foreach (var ch in _channels.RootElement.EnumerateArray())
                    {
                        var key  = ch.TryGetProperty("key",  out var k) ? k.GetString() ?? "" : "";
                        var name = ch.TryGetProperty("name", out var n) ? n.GetString() ?? key : key;
                        <option value="@key">@name</option>
                    }
                }
            </select>
        </label>
        <label>Title<input @bind="_sendTitle" /></label>
        <label>Body<textarea @bind="_sendBody" rows="3" style="width:100%;padding:.4rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.875rem"></textarea></label>
        <div style="display:flex;gap:.75rem;margin-top:.75rem">
            <button @onclick="SendNowAsync">Send Now</button>
            <div style="display:flex;gap:.5rem;align-items:center">
                <input type="datetime-local" @bind="_scheduleAt" />
                <button @onclick="ScheduleAsync">Schedule</button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(_sendMsg)) { <p class="message">@_sendMsg</p> }
    </div>
}

@if (_tab == "Scheduled")
{
    <table>
        <thead><tr><th>ID</th><th>Channel</th><th>Title</th><th>Scheduled At</th><th>Actions</th></tr></thead>
        <tbody>
            @if (_scheduled is not null)
            {
                @foreach (var el in _scheduled.RootElement.GetProperty("items").EnumerateArray())
                {
                    var id    = el.TryGetProperty("id", out var i) ? i.GetGuid() : Guid.Empty;
                    var ch    = el.TryGetProperty("channelKey",   out var c) ? c.GetString() ?? "—" : "—";
                    var title = el.TryGetProperty("title",        out var t) ? t.GetString() ?? "—" : "—";
                    var sAt   = el.TryGetProperty("scheduledAt",  out var s) ? s.GetString() ?? "—" : "—";
                    <tr>
                        <td><code>@id.ToString()[..8]…</code></td>
                        <td>@ch</td>
                        <td>@title</td>
                        <td>@sAt</td>
                        <td><button class="danger" @onclick="() => CancelAsync(id)">Cancel</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>
    @if (!string.IsNullOrEmpty(_actionMsg)) { <p class="message">@_actionMsg</p> }
}

@if (_tab == "Templates")
{
    <div style="display:flex;gap:.75rem;margin-bottom:1rem;align-items:center">
        <button @onclick="() => _showTemplateForm = !_showTemplateForm">+ New Template</button>
    </div>
    @if (_showTemplateForm)
    {
        <div class="card" style="margin-bottom:1rem">
            <h2>New Template</h2>
            <label>Name<input @bind="_tplName" /></label>
            <label>Title<input @bind="_tplTitle" /></label>
            <label>Body<textarea @bind="_tplBody" rows="2" style="width:100%;padding:.4rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.875rem"></textarea></label>
            <label>Channel Key<input @bind="_tplChannel" /></label>
            <button @onclick="CreateTemplateAsync" style="margin-top:.5rem">Save</button>
            @if (!string.IsNullOrEmpty(_tplMsg)) { <p class="message">@_tplMsg</p> }
        </div>
    }
    <table>
        <thead><tr><th>Name</th><th>Title</th><th>Channel</th><th>Actions</th></tr></thead>
        <tbody>
            @if (_templates is not null)
            {
                @foreach (var el in _templates.RootElement.EnumerateArray())
                {
                    var id    = el.TryGetProperty("id",         out var i) ? i.GetGuid() : Guid.Empty;
                    var name  = el.TryGetProperty("name",       out var n) ? n.GetString() ?? "—" : "—";
                    var title = el.TryGetProperty("title",      out var t) ? t.GetString() ?? "—" : "—";
                    var ch    = el.TryGetProperty("channelKey", out var c) ? c.GetString() ?? "—" : "—";
                    <tr>
                        <td>@name</td><td>@title</td><td>@ch</td>
                        <td><button class="danger" @onclick="() => DeleteTemplateAsync(id)">Delete</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@if (_tab == "History")
{
    <div class="filters">
        <input @bind="_histChannel" placeholder="Channel key..." />
        <select @bind="_histStatus"><option value="">All statuses</option><option>Sent</option><option>Failed</option></select>
        <button @onclick="LoadHistoryAsync">Filter</button>
    </div>
    <table>
        <thead><tr><th>Channel</th><th>Title</th><th>Status</th><th>Sent At</th></tr></thead>
        <tbody>
            @if (_history is not null && _history.RootElement.TryGetProperty("items", out var histItems))
            {
                @foreach (var el in histItems.EnumerateArray())
                {
                    var ch    = el.TryGetProperty("channelKey", out var c) ? c.GetString() ?? "—" : "—";
                    var title = el.TryGetProperty("title",      out var t) ? t.GetString() ?? "—" : "—";
                    var stat  = el.TryGetProperty("status",     out var s) ? s.GetString() ?? "—" : "—";
                    var at    = el.TryGetProperty("sentAt",     out var a) ? a.GetString() ?? "—" : "—";
                    <tr><td>@ch</td><td>@title</td><td>@stat</td><td>@at</td></tr>
                }
            }
        </tbody>
    </table>
}

@if (_tab == "Dead Letter")
{
    <table>
        <thead><tr><th>ID</th><th>Channel</th><th>Title</th><th>Failed At</th><th>Actions</th></tr></thead>
        <tbody>
            @if (_deadLetter is not null && _deadLetter.RootElement.TryGetProperty("items", out var dlItems))
            {
                @foreach (var el in dlItems.EnumerateArray())
                {
                    var id    = el.TryGetProperty("id",         out var i) ? i.GetGuid() : Guid.Empty;
                    var ch    = el.TryGetProperty("channelKey", out var c) ? c.GetString() ?? "—" : "—";
                    var title = el.TryGetProperty("title",      out var t) ? t.GetString() ?? "—" : "—";
                    var at    = el.TryGetProperty("failedAt",   out var a) ? a.GetString() ?? "—" : "—";
                    <tr>
                        <td><code>@id.ToString()[..8]…</code></td>
                        <td>@ch</td><td>@title</td><td>@at</td>
                        <td><button @onclick="() => ReplayAsync(id)">Retry</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>
    @if (!string.IsNullOrEmpty(_actionMsg)) { <p class="message">@_actionMsg</p> }
}

@code {
    private string _tab = "Send";
    private JsonDocument? _channels, _scheduled, _templates, _history, _deadLetter;

    // send form
    private string _sendChannel = string.Empty, _sendTitle = string.Empty, _sendBody = string.Empty;
    private DateTime _scheduleAt = DateTime.Now.AddHours(1);
    private string _sendMsg = string.Empty;

    // template form
    private bool _showTemplateForm;
    private string _tplName = string.Empty, _tplTitle = string.Empty, _tplBody = string.Empty, _tplChannel = string.Empty;
    private string _tplMsg = string.Empty;

    // history filters
    private string _histChannel = string.Empty, _histStatus = string.Empty;
    private string _actionMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Auth.TryAttachTokenAsync();
        _channels = await Api.ListChannelsAsync();
    }

    private async Task SwitchTab(string tab)
    {
        _tab = tab; _actionMsg = string.Empty;
        switch (tab)
        {
            case "Scheduled":   _scheduled  = await Api.ListScheduledAsync(); break;
            case "Templates":   _templates  = await Api.ListTemplatesAsync(); break;
            case "History":     await LoadHistoryAsync(); break;
            case "Dead Letter": _deadLetter = await Api.GetDeadLetterAsync(); break;
        }
    }

    private async Task SendNowAsync()
    {
        _sendMsg = string.Empty;
        var ok = await Api.SendNotificationAsync(new { channelKey = _sendChannel, title = _sendTitle, payload = _sendBody });
        _sendMsg = ok ? "Sent." : "Send failed.";
    }

    private async Task ScheduleAsync()
    {
        _sendMsg = string.Empty;
        var ok = await Api.ScheduleNotificationAsync(new { channelKey = _sendChannel, title = _sendTitle, body = _sendBody, scheduledAt = _scheduleAt });
        _sendMsg = ok ? "Scheduled." : "Schedule failed.";
    }

    private async Task CancelAsync(Guid id)
    {
        _actionMsg = string.Empty;
        var ok = await Api.CancelScheduledAsync(id);
        _actionMsg = ok ? "Cancelled." : "Cancel failed.";
        _scheduled = await Api.ListScheduledAsync();
    }

    private async Task CreateTemplateAsync()
    {
        _tplMsg = string.Empty;
        var ok = await Api.CreateTemplateAsync(new { name = _tplName, title = _tplTitle, body = _tplBody, channelKey = _tplChannel });
        _tplMsg = ok ? "Created." : "Failed.";
        if (ok) { _showTemplateForm = false; _tplName = _tplTitle = _tplBody = _tplChannel = string.Empty; }
        _templates = await Api.ListTemplatesAsync();
    }

    private async Task DeleteTemplateAsync(Guid id)
    {
        await Api.DeleteTemplateAsync(id);
        _templates = await Api.ListTemplatesAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _history = await Api.GetNotificationHistoryAsync(_histChannel, _histStatus);
    }

    private async Task ReplayAsync(Guid id)
    {
        _actionMsg = string.Empty;
        var ok = await Api.ReplayDeadLetterAsync(id);
        _actionMsg = ok ? "Replayed." : "Replay failed.";
        _deadLetter = await Api.GetDeadLetterAsync();
    }
}

<style>
    .tabs { display:flex; gap:.5rem; margin-bottom:1.25rem; }
    .tab { background:#e2e8f0; color:#475569; }
    .tab.active { background:#3b82f6; color:#fff; }
    label { display:flex; flex-direction:column; gap:.25rem; font-size:.875rem; color:#475569; margin-bottom:.6rem; }
    label input, label select, label textarea { padding:.4rem .6rem; border:1px solid #cbd5e1; border-radius:6px; font-size:.875rem; }
</style>
