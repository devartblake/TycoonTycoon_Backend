@page "/skills"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth
@using System.Text.Json

<h1>Skills</h1>

<div class="card">
    <h2>Seed Skills</h2>
    <p style="font-size:.875rem;color:#64748b;margin-bottom:1rem">
        Paste a JSON array of skill definitions. The API will upsert all entries and return the count seeded.
    </p>

    <label>
        JSON Payload
        <textarea @bind="_json" rows="14" placeholder='[
  { "key": "math", "name": "Mathematics", "description": "Arithmetic & algebra", "category": "Core" },
  { "key": "science", "name": "Science", "description": "Physics & chemistry", "category": "Core" }
]' style="font-family:monospace;font-size:.8rem;width:100%;padding:.5rem;border:1px solid #cbd5e1;border-radius:6px;resize:vertical"></textarea>
    </label>

    <button @onclick="SeedAsync" disabled="@(_seeding || string.IsNullOrWhiteSpace(_json))" style="margin-top:.75rem">
        @(_seeding ? "Seeding…" : "Seed Skills")
    </button>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="message @(_isError ? "error-msg" : "")">@_message</p>
    }

    @if (_resultJson is not null)
    {
        <pre style="margin-top:.75rem;padding:.75rem;background:#f0fdf4;border-radius:6px;font-size:.8rem;overflow-x:auto">@_resultJson</pre>
    }
</div>

<div class="card" style="margin-top:1.5rem">
    <h2>Skill JSON Schema</h2>
    <p style="font-size:.875rem;color:#64748b;margin-bottom:.5rem">Expected fields per skill object:</p>
    <table>
        <thead><tr><th>Field</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
        <tbody>
            <tr><td><code>key</code></td><td>string</td><td>Yes</td><td>Unique slug identifier (e.g. <code>math</code>)</td></tr>
            <tr><td><code>name</code></td><td>string</td><td>Yes</td><td>Display name</td></tr>
            <tr><td><code>description</code></td><td>string</td><td>No</td><td>Short description shown to players</td></tr>
            <tr><td><code>category</code></td><td>string</td><td>No</td><td>Grouping label (e.g. <code>Core</code>, <code>Advanced</code>)</td></tr>
            <tr><td><code>iconUrl</code></td><td>string</td><td>No</td><td>MinIO asset URL for the skill icon</td></tr>
            <tr><td><code>xpPerLevel</code></td><td>integer</td><td>No</td><td>XP required to advance one level (default: 100)</td></tr>
        </tbody>
    </table>
</div>

@code {
    private string _json = string.Empty;
    private bool _seeding;
    private bool _isError;
    private string _message = string.Empty;
    private string? _resultJson;

    protected override void OnInitialized() => Auth.TryAttachToken();

    private async Task SeedAsync()
    {
        _seeding = true;
        _message = string.Empty;
        _resultJson = null;
        _isError = false;

        try
        {
            var parsed = JsonDocument.Parse(_json);
            var result = await Api.SeedSkillsAsync(parsed.RootElement);
            if (result is null)
            {
                _message = "Seed failed — check API logs.";
                _isError = true;
            }
            else
            {
                var count = result.RootElement.TryGetProperty("seeded", out var c) ? c.GetInt32() : -1;
                _message = count >= 0 ? $"Seeded {count} skill(s) successfully." : "Seed request accepted.";
                _resultJson = JsonSerializer.Serialize(result.RootElement, new JsonSerializerOptions { WriteIndented = true });
            }
        }
        catch (JsonException)
        {
            _message = "Invalid JSON — check your payload.";
            _isError = true;
        }
        catch (Exception ex)
        {
            _message = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _seeding = false;
        }
    }
}

<style>
    label { display:flex; flex-direction:column; gap:.25rem; font-size:.875rem; color:#475569; margin-bottom:.5rem; }
    .error-msg { background:#fef2f2; border-left-color:#ef4444; color:#991b1b; }
    button:disabled { opacity:.5; cursor:not-allowed; }
</style>
