@page "/"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AdminAuthService Auth
@using Tycoon.Shared.Contracts.Dtos

<h1>
    Dashboard
    @if (_apiConnected == true)
    {
        <span class="api-status connected"><span class="dot"></span> API Connected</span>
    }
    else if (_apiConnected == false)
    {
        <span class="api-status unreachable"><span class="dot"></span> API Unreachable</span>
    }
</h1>

@if (_authFailed)
{
    <div class="auth-alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>Session expired.</strong> <a href="/login">Sign in again</a> to continue.</span>
    </div>
}
else if (_apiConnected == false)
{
    <div class="api-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span><strong>API unreachable.</strong> Verify the <code>tycoon-api</code> container is running and healthy, then refresh this page.</span>
    </div>
}
else
{
    <!-- KPI Cards -->
    <div class="kpi-grid">

        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Total Users</div>
                @if (_loading)
                {
                    <div class="kpi-skeleton"></div>
                }
                else
                {
                    <div class="kpi-value">@FormatNumber(_userCount)</div>
                }
                <div class="kpi-sub"><a href="/users">View users →</a></div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-purple">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Total Matches</div>
                @if (_loading)
                {
                    <div class="kpi-skeleton"></div>
                }
                else
                {
                    <div class="kpi-value">@FormatNumber(_matchCount)</div>
                }
                <div class="kpi-sub"><a href="/matches">View matches →</a></div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon kpi-icon-amber">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Active Season</div>
                @if (_loading)
                {
                    <div class="kpi-skeleton"></div>
                }
                else if (_activeSeason is null)
                {
                    <div class="kpi-value kpi-value-muted">None</div>
                    <div class="kpi-sub">No active season</div>
                }
                else
                {
                    <div class="kpi-value kpi-value-sm">@_activeSeason.Name</div>
                    <div class="kpi-sub">
                        @{
                            var daysLeft = (int)(_activeSeason.EndsAtUtc - DateTimeOffset.UtcNow).TotalDays;
                        }
                        @if (daysLeft > 0)
                        {
                            <span>@daysLeft day@(daysLeft == 1 ? "" : "s") remaining</span>
                        }
                        else
                        {
                            <span style="color:#ef4444">Ends today</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="kpi-card @(_pendingFlagCount > 0 ? "kpi-card-alert" : "")">
            <div class="kpi-icon @(_pendingFlagCount > 0 ? "kpi-icon-red" : "kpi-icon-green")">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Pending Flags</div>
                @if (_loading)
                {
                    <div class="kpi-skeleton"></div>
                }
                else
                {
                    <div class="kpi-value @(_pendingFlagCount > 0 ? "kpi-value-alert" : "")">@_pendingFlagCount</div>
                }
                <div class="kpi-sub"><a href="/anti-cheat">Review flags →</a></div>
            </div>
        </div>

    </div>

    <!-- Feature Flags -->
    @if (_config is not null)
    {
        <section class="card">
            <h2>Feature Flags</h2>
            <table>
                <thead><tr><th>Flag</th><th>State</th></tr></thead>
                <tbody>
                    @foreach (var (key, val) in _config.FeatureFlags)
                    {
                        <tr>
                            <td><code>@key</code></td>
                            <td><span class="badge @(val ? "on" : "off")">@(val ? "ON" : "OFF")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
            <p style="margin-top:1rem;font-size:.875rem;color:#64748b"><a href="/flags">Manage feature flags →</a></p>
        </section>
    }
}

@code {
    private AdminAppConfigDto? _config;
    private bool _authFailed;
    private bool? _apiConnected;
    private bool _loading = true;

    private int _userCount;
    private int _matchCount;
    private SeasonDto? _activeSeason;
    private int _pendingFlagCount;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.TryAttachTokenAsync()) { _authFailed = true; return; }

        // Fire all requests in parallel
        var t1 = Api.ListUsersAsync(null, null, 1, 1);
        var t2 = Api.ListMatchesAsync(1, 1);
        var t3 = Api.ListSeasonsAsync(1, 50);
        var t4 = Api.ListAnticheatFlagsAsync(unreviewedOnly: true, pageSize: 1);
        var t5 = Api.GetConfigAsync();

        await Task.WhenAll(t1, t2, t3, t4, t5);

        var usersDoc  = t1.Result;
        var matchDoc  = t2.Result;
        var seasons   = t3.Result;
        var flagsDoc  = t4.Result;
        _config       = t5.Result;

        _apiConnected = _config is not null;

        _userCount = GetTotal(usersDoc);
        _matchCount = GetTotal(matchDoc);

        _activeSeason = seasons?.Items.FirstOrDefault(s => s.Status == SeasonStatus.Active);

        _pendingFlagCount = GetTotal(flagsDoc);

        _loading = false;
    }

    private static string FormatNumber(int n) => n switch
    {
        >= 1_000_000 => $"{n / 1_000_000.0:0.#}M",
        >= 1_000     => $"{n / 1_000.0:0.#}K",
        _            => n.ToString()
    };

    private static int GetTotal(JsonDocument? doc)
    {
        if (doc is null || !doc.RootElement.TryGetProperty("total", out var total))
            return 0;

        return total.ValueKind switch
        {
            JsonValueKind.Number when total.TryGetInt32(out var n) => n,
            JsonValueKind.String when int.TryParse(total.GetString(), out var n) => n,
            _ => 0
        };
    }
}
